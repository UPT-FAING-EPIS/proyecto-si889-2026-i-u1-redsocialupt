{
	admin off
	auto_https off
}

:80 {
	root * /srv
	encode zstd gzip

	@html path_regexp html .*\.html$
	header @html Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
	header @html Pragma "no-cache"
	header @html Expires "0"

	@jscss path_regexp jscss ^/(js|css)/.*\.(js|css)$
	header @jscss Cache-Control "no-cache, must-revalidate"

	respond /__ome_manifest_pending__ 204

	handle_path /ome-ready/* {
		header Cache-Control "no-store"
		reverse_proxy ovenmediaengine:3333
	}

	handle_path /ome/* {
		header Cache-Control "no-store"
		reverse_proxy ovenmediaengine:3333
	}

	handle_path /ome-ws/* {
		header Cache-Control "no-store"
		reverse_proxy ovenmediaengine:3333
	}

	handle /uploads/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy posts-service:8000
	}

	handle /auth-uploads/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy auth-service:8000
	}

	handle /chat-uploads/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy chat-service:8000
	}

	handle /group-covers/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy profile-social-service:8000
	}

	handle /api/auth* {
		reverse_proxy auth-service:8000
	}

	handle /api/users* {
		reverse_proxy auth-service:8000
	}

	handle /api/admin* {
		reverse_proxy auth-service:8000
	}

	handle /api/posts* {
		reverse_proxy posts-service:8000
	}

	handle /api/comments* {
		reverse_proxy posts-service:8000
	}

	handle /api/livestreams* {
		reverse_proxy posts-service:8000
	}

	handle /api/group-posts* {
		reverse_proxy posts-service:8000
	}

	handle /api/directory* {
		reverse_proxy profile-social-service:8000
	}

	handle /api/friends* {
		reverse_proxy profile-social-service:8000
	}

	handle /api/blocks* {
		reverse_proxy profile-social-service:8000
	}

	handle /api/groups* {
		reverse_proxy profile-social-service:8000
	}

	handle /api/chat* {
		reverse_proxy chat-service:8000
	}

	handle {
		header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
		header Pragma "no-cache"
		header Expires "0"
		try_files {path} {path}/ /index.html
		file_server
	}
}

{
    "name": "redsocial-upt/auth-service",
    "description": "Servicio de autenticación con Google OAuth para Red Social UPT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/lumen-framework": "^10.0",
        "firebase/php-jwt": "^6.10",
        "google/apiclient": "^2.15"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
